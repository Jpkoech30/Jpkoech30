# ═══════════════════════════════════════════════════════════════════════════════
# JENGA AGENCY — 3rd-Party Token Template
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your tokens.
# .env is gitignored — never commit secrets.
#
# Full documentation: .agency/SECRETS.md
# ═══════════════════════════════════════════════════════════════════════════════

# ── GitHub API ──────────────────────────────────────────────────────────────
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, admin:repo_hook
# GITHUB_TOKEN=ghp_your_token_here

# ── Telegram Notifications ──────────────────────────────────────────────────
# Create bot via @BotFather, get chat ID via @userinfobot
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# ── HITL (Human-in-the-Loop) ────────────────────────────────────────────────
# HITL_TELEGRAM_BOT_TOKEN=your_hitl_bot_token
# HITL_TELEGRAM_CHAT_ID=your_hitl_chat_id
# HITL_PORT=3177
# HITL_CALLBACK_TOKEN=your_callback_token

# ── Database ────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/jengabooks
# DATABASE_URL_TEST=postgresql://user:pass@localhost:5432/jengabooks_test
