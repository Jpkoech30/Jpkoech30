{
  "contractId": "mobile-etims",
  "version": "1.1.0",
  "description": "eTIMS/KRA endpoints consumed by the JengaBooks mobile app. Extended with SIM-inspired invoice templates (10+) and one-click invoice duplicate.",
  "basePath": "/api/v1",
  "endpoints": [
    {
      "method": "GET",
      "path": "/etims/invoices",
      "auth": true,
      "description": "List eTIMS invoices",
      "request": {
        "query": {
          "page": { "type": "number", "default": 1 },
          "limit": { "type": "number", "default": 20 },
          "status": { "type": "string", "enum": ["DRAFT", "SENT", "PAID", "OVERDUE", "CANCELLED"], "optional": true }
        }
      },
      "response": {
        "200": {
          "body": {
            "items": { "type": "array", "items": { "$ref": "#/types/Invoice" } },
            "total": { "type": "number" },
            "page": { "type": "number" },
            "totalPages": { "type": "number" }
          }
        }
      }
    },
    {
      "method": "POST",
      "path": "/etims/invoices",
      "auth": true,
      "description": "Create an invoice",
      "request": {
        "body": {
          "customerName": { "type": "string", "minLength": 1, "maxLength": 200, "required": true },
          "customerPin": { "type": "string", "length": 11, "pattern": "^[A-Z0-9]{11}$", "optional": true },
          "customerEmail": { "type": "string", "format": "email", "optional": true },
          "templateId": { "type": "string", "optional": true, "description": "Invoice template ID for professional formatting" },
          "lineItems": {
            "type": "array",
            "minItems": 1,
            "required": true,
            "items": {
              "type": "object",
              "properties": {
                "description": { "type": "string", "required": true },
                "quantity": { "type": "number", "positive": true, "required": true },
                "unitPrice": { "type": "number", "positive": true, "required": true },
                "productId": { "type": "string", "format": "uuid", "optional": true }
              }
            }
          },
          "taxCode": { "type": "string", "enum": ["E", "S", "Z"], "default": "S" },
          "dueDate": { "type": "string", "format": "datetime", "optional": true },
          "notes": { "type": "string", "maxLength": 500, "optional": true },
          "currency": { "type": "string", "enum": ["KES", "USD", "EUR", "GBP"], "default": "KES", "optional": true }
        }
      },
      "response": {
        "201": { "body": { "$ref": "#/types/Invoice" } },
        "422": { "body": { "message": "Validation failed" } }
      }
    },
    {
      "method": "GET",
      "path": "/etims/invoices/{id}",
      "auth": true,
      "description": "Get invoice detail with eTIMS submission status",
      "response": {
        "200": { "body": { "$ref": "#/types/Invoice" } }
      }
    },
    {
      "method": "POST",
      "path": "/etims/submissions/{id}/submit",
      "auth": true,
      "description": "Submit invoice to KRA eTIMS",
      "response": {
        "200": {
          "body": {
            "submission": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "serialNumber": { "type": "string" },
                "status": { "type": "string", "enum": ["PENDING", "SUBMITTED", "ACCEPTED", "FAILED"] },
                "submittedAt": { "type": "string", "format": "datetime" }
              }
            }
          }
        }
      }
    },
    {
      "method": "GET",
      "path": "/etims/compliance-shield",
      "auth": true,
      "description": "Get compliance shield summary (accepted vs total invoices)",
      "response": {
        "200": {
          "body": {
            "totalInvoices": { "type": "number" },
            "acceptedInvoices": { "type": "number" },
            "failedInvoices": { "type": "number" },
            "pendingSubmission": { "type": "number" },
            "complianceRate": { "type": "number", "description": "Percentage 0-100" }
          }
        }
      }
    },
    {
      "method": "GET",
      "path": "/etims/invoice-templates",
      "auth": true,
      "description": "List available professional invoice templates (SIM-inspired 10+ templates)",
      "response": {
        "200": {
          "body": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string", "description": "Template display name" },
                  "description": { "type": "string" },
                  "previewUrl": { "type": "string", "description": "Thumbnail preview URL" },
                  "category": { "type": "string", "enum": ["PROFESSIONAL", "MODERN", "MINIMAL", "CLASSIC", "COLORFUL", "CORPORATE"] },
                  "isDefault": { "type": "boolean" },
                  "supportsLogo": { "type": "boolean" },
                  "supportsSignature": { "type": "boolean" },
                  "colorScheme": {
                    "type": "object",
                    "properties": {
                      "primary": { "type": "string" },
                      "secondary": { "type": "string" },
                      "accent": { "type": "string" }
                    }
                  }
                }
              }
            },
            "total": { "type": "number" }
          }
        }
      }
    },
    {
      "method": "POST",
      "path": "/etims/invoices/{id}/duplicate",
      "auth": true,
      "description": "One-click duplicate an existing invoice (SIM-inspired feature). Creates a DRAFT copy with all line items.",
      "response": {
        "201": {
          "body": {
            "originalInvoiceId": { "type": "string", "format": "uuid" },
            "newInvoiceId": { "type": "string", "format": "uuid" },
            "newInvoiceNumber": { "type": "string" },
            "status": { "type": "string", "default": "DRAFT" },
            "message": { "type": "string", "default": "Invoice duplicated. Review and send." }
          }
        }
      }
    },
    {
      "method": "POST",
      "path": "/etims/invoices/{id}/apply-template",
      "auth": true,
      "description": "Apply a different invoice template to an existing invoice",
      "request": {
        "body": {
          "templateId": { "type": "string", "required": true }
        }
      },
      "response": {
        "200": {
          "body": {
            "invoiceId": { "type": "string" },
            "templateId": { "type": "string" },
            "previewUrl": { "type": "string", "description": "Updated PDF preview URL" }
          }
        }
      }
    }
  ],
  "types": {
    "Invoice": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "invoiceNumber": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPin": { "type": "string", "optional": true },
        "customerEmail": { "type": "string", "optional": true },
        "subtotal": { "type": "number" },
        "vat": { "type": "number" },
        "total": { "type": "number" },
        "taxCode": { "type": "string" },
        "status": { "type": "string", "enum": ["DRAFT", "SENT", "PAID", "OVERDUE", "CANCELLED"] },
        "dueDate": { "type": "string", "format": "datetime", "optional": true },
        "templateId": { "type": "string", "optional": true },
        "currency": { "type": "string", "default": "KES", "optional": true },
        "lineItems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" },
              "total": { "type": "number" },
              "productId": { "type": "string", "optional": true }
            }
          }
        },
        "etimsSubmission": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "serialNumber": { "type": "string" },
            "status": { "type": "string", "enum": ["PENDING", "SUBMITTED", "ACCEPTED", "FAILED"] },
            "submittedAt": { "type": "string", "format": "datetime", "optional": true }
          },
          "optional": true
        },
        "createdAt": { "type": "string", "format": "datetime" }
      }
    }
  },
  "changelog": [
    { "date": "2026-07-09", "version": "1.0.0", "description": "Initial mobile eTIMS contract" },
    { "date": "2026-07-09", "version": "1.1.0", "description": "Added invoice templates (10+), one-click duplicate, templateId and currency fields — SIM-inspired features" }
  ]
}
