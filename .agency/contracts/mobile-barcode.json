{
  "contractId": "mobile-barcode",
  "version": "1.0.0",
  "description": "Barcode/QR Scanner endpoints — scan barcodes/QR codes to look up products, invoices, clients, and perform quick actions (SIM-inspired)",
  "basePath": "/api/v1",
  "endpoints": [
    {
      "method": "POST",
      "path": "/barcode/lookup",
      "auth": true,
      "description": "Look up an entity by scanned barcode or QR code value",
      "request": {
        "body": {
          "code": { "type": "string", "minLength": 1, "maxLength": 200, "required": true, "description": "Scanned barcode/QR code value" },
          "type": { "type": "string", "enum": ["AUTO", "PRODUCT", "INVOICE", "CLIENT"], "default": "AUTO", "optional": true }
        }
      },
      "response": {
        "200": {
          "body": {
            "entityType": { "type": "string", "enum": ["PRODUCT", "INVOICE", "CLIENT", "UNKNOWN"] },
            "entity": { "type": "object", "description": "The resolved entity object (Product, Invoice, or Client depending on entityType)" },
            "matchMethod": { "type": "string", "enum": ["SKU", "INVOICE_NUMBER", "CLIENT_CODE", "QR_TOKEN", "UNIQUE_ID"] },
            "confidence": { "type": "number", "description": "Match confidence 0-1" }
          }
        },
        "404": { "body": { "entityType": "UNKNOWN", "entity": null, "matchMethod": null, "confidence": 0 } }
      }
    },
    {
      "method": "POST",
      "path": "/barcode/generate-qr",
      "auth": true,
      "description": "Generate a QR code for an invoice (for payment or sharing)",
      "request": {
        "body": {
          "entityType": { "type": "string", "enum": ["INVOICE", "RECEIPT", "CREDIT_NOTE"], "required": true },
          "entityId": { "type": "string", "format": "uuid", "required": true },
          "includePaymentInfo": { "type": "boolean", "default": true, "optional": true, "description": "Include M-Pesa paybill/till in QR data" }
        }
      },
      "response": {
        "200": {
          "body": {
            "qrDataUrl": { "type": "string", "description": "Base64 PNG data URL of the QR code" },
            "qrText": { "type": "string", "description": "Raw text encoded in QR" },
            "deepLink": { "type": "string", "optional": true, "description": "M-Pesa deep link for payment QR" }
          }
        }
      }
    },
    {
      "method": "POST",
      "path": "/barcode/quick-invoice",
      "auth": true,
      "description": "Quick-create an invoice by scanning a product barcode and entering quantity",
      "request": {
        "body": {
          "productCode": { "type": "string", "required": true, "description": "Scanned product barcode/SKU" },
          "quantity": { "type": "number", "positive": true, "default": 1, "optional": true },
          "clientId": { "type": "string", "format": "uuid", "required": true }
        }
      },
      "response": {
        "201": {
          "body": {
            "invoiceId": { "type": "string", "format": "uuid" },
            "invoiceNumber": { "type": "string" },
            "lineItem": {
              "type": "object",
              "properties": {
                "productId": { "type": "string" },
                "productName": { "type": "string" },
                "quantity": { "type": "number" },
                "unitPrice": { "type": "number" },
                "total": { "type": "number" }
              }
            },
            "total": { "type": "number" }
          }
        },
        "404": { "body": { "message": "Product not found for barcode" } }
      }
    }
  ],
  "types": {},
  "changelog": [
    { "date": "2026-07-09", "version": "1.0.0", "description": "Barcode/QR scanner contract — SIM-inspired scan-to-lookup and scan-to-invoice" }
  ]
}
