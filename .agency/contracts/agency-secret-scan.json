{
    "contractId": "agency-secret-scan",
    "version": "1.0.0",
    "description": "Pre-commit secret scanning — blocks commits containing hardcoded secrets, API keys, and credentials",
    "hooks": {
        "preCommit": {
            "script": ".agency/scripts/secret-scan.js",
            "integration": "Append to .husky/pre-commit alongside lint-staged",
            "exitOnFailure": true,
            "errorMessage": "❌ SECURITY BLOCK: Potential secret detected in staged files. Review and remove before committing."
        }
    },
    "scanPatterns": {
        "highPriority": {
            "description": "These patterns ALWAYS block the commit",
            "patterns": [
                {
                    "name": "AWS Access Key",
                    "regex": "AKIA[0-9A-Z]{16}",
                    "severity": "CRITICAL"
                },
                {
                    "name": "Generic Secret",
                    "regex": "(?i)(secret|password|api[_-]?key|private[_-]?key|token)\\s*[:=]\\s*['\"][A-Za-z0-9_\\-]{16,}['\"]",
                    "severity": "HIGH"
                },
                {
                    "name": "JWT Secret",
                    "regex": "(?i)(jwt[_-]?secret|session[_-]?secret)\\s*[:=]\\s*['\"][A-Za-z0-9_\\-]{16,}['\"]",
                    "severity": "CRITICAL"
                },
                {
                    "name": "Private Key Block",
                    "regex": "-----BEGIN\\s+(RSA|DSA|EC|OPENSSH)\\s+PRIVATE\\s+KEY-----",
                    "severity": "CRITICAL"
                },
                {
                    "name": "GitHub Token",
                    "regex": "gh[pousr]_[A-Za-z0-9_]{36,}",
                    "severity": "HIGH"
                },
                {
                    "name": "Slack Token",
                    "regex": "xox[baprs]-[A-Za-z0-9\\-]{10,}",
                    "severity": "HIGH"
                },
                {
                    "name": ".env File",
                    "regex": "\\.env$",
                    "severity": "HIGH",
                    "matchFilename": true
                },
                {
                    "name": "Heroku API Key",
                    "regex": "(?i)heroku[a-z0-9_\\-]*\\s*[:=]\\s*['\"][A-Za-z0-9\\-]{36,}['\"]",
                    "severity": "HIGH"
                },
                {
                    "name": "MongoDB Connection String",
                    "regex": "mongodb[+srv]*:\\/\\/[^\\s]+",
                    "severity": "HIGH"
                },
                {
                    "name": "PostgreSQL Connection String",
                    "regex": "postgresql?:\\/\\/[^\\s]+",
                    "severity": "HIGH"
                }
            ]
        },
        "whitelist": {
            "description": "Patterns that are EXEMPTED from scanning (configure in .agency/config.json)",
            "configKey": "secretScan.whitelist",
            "defaultPatterns": [
                {
                    "pattern": "TEST_PASSWORD",
                    "reason": "Test fixtures"
                },
                {
                    "pattern": "EXAMPLE_API_KEY",
                    "reason": "Example/demo values"
                },
                {
                    "pattern": "placeholder",
                    "reason": "Template placeholders"
                },
                {
                    "pattern": "\\.env\\.example$",
                    "reason": "Example env files are safe templates"
                }
            ]
        },
        "excludedFiles": {
            "description": "Files that are SKIPPED during secret scanning",
            "defaults": [
                "*.spec.ts",
                "*.test.ts",
                "*.md",
                "package-lock.json",
                "yarn.lock",
                "*.min.js",
                "*.min.css"
            ]
        }
    },
    "output": {
        "onPass": "✅ Secret scan passed — no secrets detected in staged files",
        "onFail": {
            "message": "❌ SECURITY BLOCK: ${count} potential secret(s) detected in staged files:",
            "detailFormat": "  - ${file}:${line} — ${pattern_name} (${severity})",
            "resolution": "Run 'node .agency/scripts/secret-scan.js --show-details' to see exact matches, then remove them before committing."
        }
    },
    "integrationPoints": [
        "Append to .husky/pre-commit",
        "Config whitelist stored in .agency/config.json under secretScan.whitelist"
    ],
    "changelog": [
        {
            "date": "2026-07-10",
            "version": "1.0.0",
            "description": "Initial secret scanning contract"
        }
    ]
}