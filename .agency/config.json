{
  "agency": {
    "name": "JengaBooks Agency",
    "version": "1.0.0",
    "description": "Multi-agent orchestration system for JengaBooks development"
  },
  "agents": {
    "enabled": [
      "lead-architect",
      "backend-lead",
      "backend-api",
      "backend-service",
      "backend-integration",
      "backend-database",
      "frontend-lead",
      "frontend-ui",
      "frontend-page",
      "frontend-state",
      "frontend-web",
      "frontend-mobile",
      "mobile-lead",
      "mobile-ui",
      "mobile-screen",
      "mobile-state",
      "devops-lead",
      "devops-infra",
      "devops-cicd",
      "devops-db",
      "compliance-guardian",
      "security-auditor",
      "performance-auditor",
      "accessibility-auditor",
      "qa-automator",
      "documentarian",
      "design-keeper",
      "release-manager",
      "code-agent"
    ],
    "hierarchy": {
      "orchestrator": "lead-architect",
      "leads": [
        "backend-lead",
        "frontend-lead",
        "mobile-lead",
        "devops-lead"
      ],
      "specialists": [
        "backend-api",
        "backend-service",
        "backend-integration",
        "backend-database",
        "frontend-ui",
        "frontend-page",
        "frontend-state",
        "frontend-web",
        "frontend-mobile",
        "mobile-ui",
        "mobile-screen",
        "mobile-state",
        "devops-infra",
        "devops-cicd",
        "devops-db"
      ],
      "qualityGates": [
        "compliance-guardian",
        "security-auditor",
        "performance-auditor",
        "accessibility-auditor",
        "qa-automator"
      ],
      "support": [
        "documentarian",
        "design-keeper",
        "release-manager",
        "code-agent"
      ],
      "triage": {
        "bypass_keywords": [
          "hotfix",
          "patch",
          "typo",
          "css",
          "color",
          "font",
          "copy",
          "text change"
        ],
        "max_bypass_word_count": 100,
        "direct_route": {
          "frontend-ui": [
            "frontend-lead"
          ],
          "backend-typo": [
            "code-agent"
          ]
        }
      }
    },
    "handoffProtocol": {
      "requiredCommitBodyFields": [
        "HANDOFF",
        "ARTIFACTS",
        "CONTRACT",
        "MEMORY",
        "STATUS",
        "SCOPE"
      ],
      "trackingFile": "ORCHESTRATION.md",
      "statusValues": [
        "PENDING",
        "IN_PROGRESS",
        "REVIEW",
        "DONE",
        "BLOCKED"
      ]
    }
  },
  "contracts": {
    "directory": ".agency/contracts/",
    "format": "json",
    "requiredFields": [
      "contractId",
      "version",
      "endpoints",
      "types",
      "changelog"
    ]
  },
  "workflows": {
    "featureTypes": {
      "A": {
        "name": "UI-only",
        "pipeline": [
          "frontend-ui",
          "frontend-page",
          "frontend-state",
          "frontend-lead"
        ]
      },
      "B": {
        "name": "API+UI",
        "pipeline": [
          "backend-api",
          "backend-service",
          "backend-integration",
          "backend-lead",
          "frontend-ui",
          "frontend-page",
          "frontend-state",
          "frontend-lead"
        ]
      },
      "C": {
        "name": "DB+API+UI",
        "pipeline": [
          "backend-database",
          "backend-api",
          "backend-service",
          "backend-integration",
          "backend-lead",
          "frontend-ui",
          "frontend-page",
          "frontend-state",
          "frontend-lead"
        ]
      },
      "D": {
        "name": "Backend-only",
        "pipeline": [
          "backend-api",
          "backend-service",
          "backend-integration",
          "backend-lead"
        ]
      },
      "E": {
        "name": "Mobile-only",
        "pipeline": [
          "mobile-ui",
          "mobile-screen",
          "mobile-state",
          "mobile-lead"
        ]
      },
      "F": {
        "name": "Full-stack+mobile",
        "pipeline": [
          "backend-database",
          "backend-api",
          "backend-service",
          "backend-integration",
          "backend-lead",
          "frontend-ui",
          "frontend-page",
          "frontend-state",
          "frontend-lead",
          "mobile-ui",
          "mobile-screen",
          "mobile-state",
          "mobile-lead"
        ]
      },
      "G": {
        "name": "Infrastructure",
        "pipeline": [
          "devops-infra",
          "devops-cicd",
          "devops-db",
          "devops-lead"
        ]
      },
      "H": {
        "name": "Hotfix",
        "pipeline": [
          "code-agent"
        ]
      }
    },
    "qualityGatesAfter": [
      "compliance-guardian",
      "security-auditor",
      "qa-automator"
    ],
    "releaseAfter": [
      "release-manager"
    ]
  },
  "secretScan": {
    "whitelist": [
      {
        "pattern": "TEST_PASSWORD",
        "reason": "Test fixtures"
      },
      {
        "pattern": "EXAMPLE_API_KEY",
        "reason": "Example/demo values"
      },
      {
        "pattern": "placeholder",
        "reason": "Template placeholders"
      },
      {
        "pattern": "\\.env\\.example$",
        "reason": "Example env files are safe templates"
      }
    ]
  },
  "hitl": {
    "callbackUrl": "http://localhost:3177/webhook/approve",
    "serverPort": 3177
  },
  "thresholds": {
    "history": [
      {
        "archived_at": "2026-07-12T22:08:47.746Z"
      }
    ],
    "quality_gate_max_tokens": 10000,
    "enforcer_pre_ttl": 7200,
    "memory_ttl_days": 90,
    "min_recall_score": 0.5,
    "_last_error_rate": 0,
    "_generated_at": "2026-07-12T22:08:47.745Z",
    "_events_analyzed": 47
  }
}