#!/usr/bin/env node
const { execSync } = require("child_process");
const fs = require("fs");
const path = require("path");

// ── Post-commit validations (blocking - errors are reported) ────────────────
try { execSync("node .agency/scripts/auto-docs.js --sync", { stdio: "inherit" }); } catch (e) { console.error("  ⚠ auto-docs failed:", e.message); }
try { execSync("node .agency/scripts/cost-report.js --output .agency/reports/cost-running.md", { stdio: "inherit" }); } catch (e) { console.error("  ⚠ cost-report failed:", e.message); }

// npm test (only if "test" script exists)
try { execSync("node -e \"const p=require('./package.json');process.exit(p.scripts&&p.scripts.test?0:1)\"", { stdio: "inherit" }); execSync("npm test 2>&1", { stdio: "inherit", timeout: 60000 }); } catch (e) { console.error("  ⚠ npm test failed:", e.message); }

// tsc --noEmit (only if tsconfig.json exists)
try { if (fs.existsSync(path.join(__dirname, '..', 'tsconfig.json'))) { execSync("npx tsc --noEmit 2>&1", { stdio: "inherit", timeout: 60000 }); } } catch (e) { console.error("  ⚠ tsc check failed:", e.message); }

// npm audit (non-fatal)
try { execSync("npm audit 2>&1", { stdio: "inherit", timeout: 30000 }); } catch (e) { console.error("  ⚠ npm audit found issues:", e.message); }

// Multi-branch push
try {
    const defaultBranch = execSync("git rev-parse --abbrev-ref HEAD", { encoding: "utf-8" }).toString().trim();
    execSync(`git push origin ${defaultBranch}`, { stdio: "inherit" });
} catch (e) { console.error("  ⚠ git push failed:", e.message); }
